# Conexao com o banco SQL Server (compartilhada por todas as tabelas
# monitoradas - o sistema suporta multiplas tabelas simultaneamente, desde
# que estejam neste mesmo servidor/banco).
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=db_automacao
DB_USER=sa
DB_PASSWORD=changeme
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# DB_SCHEMA / DB_TABLE / DB_TIMESTAMP_COLUMN abaixo sao LEGADOS: usados
# somente na migracao automatica da primeira execucao apos esta atualizacao
# (para preservar a tabela e a configuracao que ja existiam antes do sistema
# suportar multiplas tabelas). Tabelas novas sao cadastradas pela tela
# "Tabelas monitoradas" (pagina inicial do sistema), nao pelo .env.
DB_SCHEMA=dbo
DB_TABLE=tab_monitor_sensores_amonia_BGE
DB_TIMESTAMP_COLUMN=E3TimeStamp

# false = a coluna acima guarda horario LOCAL (sem timezone), que e o caso mais
# comum de tabelas alimentadas por CLP/SCADA. Deixe false para o horario exibido
# no app bater com o horario mostrado no SSMS. So mude para true se a coluna
# realmente guardar horario em UTC.
DB_USE_UTC=false

# Valor da coluna *_Quality considerado confiavel
RELIABLE_QUALITY_VALUE=192

# Leitura acima deste valor e tratada como ERRO de sensor (mesmo status de
# "falha" usado hoje para valores negativos) no dashboard e no painel do
# Grafana. Util para descartar leituras absurdas (ex.: pico de ruido do CLP).
MAX_SENSOR_VALUE=10000

# Porta HTTP do servidor Node
HTTP_PORT=3000

# Origens liberadas para chamar a API via fetch/CORS (ex.: o painel do Grafana).
# '*' libera qualquer origem. Para restringir, use uma ou mais URLs separadas
# por virgula, ex.: https://grafana.minhaempresa.com,https://outro-dominio.com
CORS_ORIGIN=*

# Valores padrao usados apenas na primeira execucao (depois ficam salvos em config/settings.json)
DEFAULT_GROUP_INTERVAL_MINUTES=10
DEFAULT_UPDATE_INTERVAL_MINUTES=10
HISTORY_HOURS=24

# Se true, o sistema salva uma copia das leituras dos sensores habilitados de
# CADA tabela monitorada numa tabela separada chamada "<tabela>_viewer" (ex.:
# tab_monitor_sensores_amonia_BGE_viewer), com colunas [Sensor] e
# [Sensor]_Quality no mesmo padrao da tabela original (a coluna _Quality e
# sintetica: RELIABLE_QUALITY_VALUE quando ha valor, NULL quando nao ha
# leitura confiavel no intervalo). A tabela e criada automaticamente se nao
# existir, e colunas novas sao adicionadas conforme mais sensores sao
# habilitados. A tabela ORIGINAL nunca e alterada.
SAVE_TO_DB_ENABLED=false

# true  = a tabela _viewer nunca apaga registros antigos (vira um historico
#         permanente que so cresce).
# false = a tabela _viewer e podada a cada sincronizacao para conter
#         exatamente a mesma janela de HISTORY_HOURS que esta no cache/JSON
#         (registros mais antigos que a janela sao removidos).
SAVE_TO_DB_HISTORY_MODE=false
